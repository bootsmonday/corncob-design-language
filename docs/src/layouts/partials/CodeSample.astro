---
const { id = 'example' } = Astro.props;
---

<div id={id} class="corn-docs-code">
  <corn-button-bar class="corn-button-bar corn-button-bar--toolbar">
    <corn-copy-button
      class="corn-copy-button"
      copyselector={`#${id} pre code`}
      copysuccess="Text copied to clipboard"
      copyfailure="Failed to copy"
    >
      <button
        class="corn-button corn-button--xs"
        aria-controls={id}
        aria-label="Copy text to clipboard"
      >
        copy
      </button>
      <div role="status" aria-live="polite" class="corn-copy-button--message corn-assistive-text">
      </div>
    </corn-copy-button>
    <div class="corn-popover--anchor corn-button-bar--more">
      <button class="corn-button corn-button--xs corn-pop" aria-controls="button-bar-popover">
        More
      </button>
      <corn-popover position="bottom" id="button-bar-popover" class="corn-popover"></corn-popover>
    </div>
  </corn-button-bar>

  <slot />
</div>
