{
  "name": "@corncob/design-language",
  "version": "0.0.1",
  "description": "Corncob Design Language - A vanilla JavaScript design system",
  "main": "dist/corncob-design-language.js",
  "module": "dist/corncob-design-language.esm.js",
  "style": "dist/corncob-design-language.css",
  "files": [
    "dist"
  ],
  "workspaces": [
    "packages/react",
    "packages/vue"
  ],
  "exports": {
    ".": "./dist/corncob-design-language.esm.js",
    "./style.css": "./dist/corncob-design-language.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "overrides": {
    "@ibm/telemetry-js": "npm:empty-npm-package@1.0.0"
  },
  "scripts": {
    "is:dev": "node testing/check-dev.js",
    "start-if-not-dev": "npm run is:dev || npm run dev",
    "accessibility:test": "npm run is:dev && node ./testing/accessibility/axe-tests.js",
    "accessibility:test:local": "npm run start-if-not-dev && node ./testing/accessibility/axe-tests.js",
    "visual:test": "npm run is:dev && backstop test --config='backstop.config.js'",
    "visual:approve": "backstop approve --config='backstop.config.js'",
    "visual:reference": "npm run is:dev && backstop reference --config='backstop.config.js'",
    "dev": "vite --host ",
    "build": "vite build && npm run docs:sync-dist",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "docs:sync-dist": "mkdir -p docs/public/assets && rsync -a --delete --exclude='*.html' dist/ docs/public/assets/",
    "docs:dev": "npm run docs:sync-dist && cd docs && astro dev --host",
    "docs:build": "npm run docs:sync-dist && cd docs && astro build",
    "docs:preview": "npm run docs:sync-dist && cd docs && astro preview --host --port 4322",
    "wrappers:build": "npm run -w @corncob/design-language-react build && npm run -w @corncob/design-language-vue build",
    "wrappers:test": "npm run -w @corncob/design-language-react test && npm run -w @corncob/design-language-vue test",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint:css": "stylelint src/**/*.css",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "keywords": [
    "design-system",
    "component-library",
    "vanilla-js",
    "enterprise"
  ],
  "author": "Corncob Team",
  "license": "BSL-1.0",
  "devDependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.1",
    "@astrojs/vue": "^6.0.1",
    "@axe-core/playwright": "^4.11.1",
    "@babel/preset-env": "^7.29.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@happy-dom/jest-environment": "^20.8.4",
    "@testing-library/dom": "^10.4.1",
    "astro": "^6.0.8",
    "backstopjs": "^6.3.25",
    "bootstrap-icons": "^1.13.1",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "modern-normalize": "^3.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.1.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "vite": "^7.3.1",
    "vite-plugin-string": "^1.2.3"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vue": "^3.5.30"
  }
}
