{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Corncob Design Language",
  "version": "1.0.0",
  "description": "Lightweight, accessible vanilla JS design system. Perfect for AI-assisted website and application development.",
  "prefix": "corn-",
  "components": {
    "button": {
      "name": "Button",
      "description": "Primary action and interactive button component",
      "baseClass": "corn-button",
      "variants": ["primary", "secondary", "outline", "ghost", "danger"],
      "sizes": ["sm", "md", "lg"],
      "jsRequired": false,
      "accessibility": "Fully keyboard accessible, proper ARIA roles",
      "example": "<button class=\"corn-button corn-button--primary\">Primary Action</button>",
      "fullExamples": {
        "primary": "<button class=\"corn-button corn-button--primary\">Primary</button>",
        "secondary": "<button class=\"corn-button corn-button--secondary\">Secondary</button>",
        "large-danger": "<button class=\"corn-button corn-button--danger corn-button--lg\">Large Danger</button>"
      }
    },
    "input": {
      "name": "Input",
      "description": "Text input field with label and error state support",
      "baseClass": "corn-input",
      "variants": ["error"],
      "sizes": ["sm", "md", "lg"],
      "jsRequired": false,
      "accessibility": "Paired with corn-label, supports aria-invalid",
      "example": "<label class=\"corn-label\">Label <input type=\"text\" class=\"corn-input\" /></label>"
    },
    "textarea": {
      "name": "Textarea",
      "description": "Resizable multi-line text input",
      "baseClass": "corn-textarea",
      "variants": ["error"],
      "jsRequired": false,
      "example": "<textarea class=\"corn-textarea\" rows=\"4\"></textarea>"
    },
    "select": {
      "name": "Select",
      "description": "Custom dropdown with keyboard navigation",
      "baseClass": "corn-select",
      "jsRequired": true,
      "example": "<select class=\"corn-select\"></select>"
    },
    "checkbox": {
      "name": "Checkbox",
      "description": "Checkbox input for single or grouped selections",
      "baseClass": "corn-checkbox",
      "jsRequired": false,
      "example": "<label><input type=\"checkbox\" class=\"corn-checkbox\"> Option</label>"
    },
    "radio": {
      "name": "Radio",
      "description": "Radio button for single selection in a group",
      "baseClass": "corn-radio",
      "jsRequired": false,
      "example": "<label><input type=\"radio\" name=\"group\" class=\"corn-radio\"> Option</label>"
    },
    "toggle": {
      "name": "Toggle",
      "description": "On/off switch (toggle)",
      "baseClass": "corn-toggle",
      "jsRequired": true,
      "example": "<label class=\"corn-toggle\"><input type=\"checkbox\"><span class=\"corn-toggle__slider\"></span></label>"
    },
    "card": {
      "name": "Card",
      "description": "Content container with optional header, body, and footer",
      "baseClass": "corn-card",
      "subComponents": ["corn-card__header", "corn-card__body", "corn-card__footer"],
      "jsRequired": false,
      "example": "<div class=\"corn-card\"><div class=\"corn-card__header\">Title</div><div class=\"corn-card__body\">Content</div></div>"
    },
    "modal": {
      "name": "Modal",
      "description": "Accessible dialog/modal with focus trap and ESC support",
      "baseClass": "corn-modal",
      "jsRequired": true,
      "accessibility": "Includes focus management and ARIA dialog role",
      "example": "<div class=\"corn-modal\" role=\"dialog\">...</div>"
    },
    "tabs": {
      "name": "Tabs",
      "description": "Horizontal tab navigation",
      "baseClass": "corn-tabs",
      "jsRequired": true,
      "example": "<div class=\"corn-tabs\">...</div>"
    },
    "table": {
      "name": "Table",
      "description": "Data table with striped rows and hover states",
      "baseClass": "corn-table",
      "variants": ["striped", "hover"],
      "jsRequired": false,
      "example": "<table class=\"corn-table striped\">...</table>"
    },
    "alert": {
      "name": "Alert",
      "description": "Status banners (success, info, warning, error)",
      "baseClass": "corn-alert",
      "variants": ["success", "info", "warning", "error"],
      "jsRequired": false,
      "example": "<div class=\"corn-alert corn-alert--success\">Success message</div>"
    },
    "badge": {
      "name": "Badge",
      "description": "Small status or count indicator",
      "baseClass": "corn-badge",
      "variants": ["primary", "secondary", "success", "danger"],
      "jsRequired": false,
      "example": "<span class=\"corn-badge corn-badge--primary\">New</span>"
    },
    "avatar": {
      "name": "Avatar",
      "description": "User avatar with image or initials fallback",
      "baseClass": "corn-avatar",
      "jsRequired": false,
      "example": "<div class=\"corn-avatar\">JD</div>"
    },
    "tooltip": {
      "name": "Tooltip",
      "description": "CSS-based tooltip with accessibility fallbacks",
      "baseClass": "corn-tooltip",
      "jsRequired": false,
      "example": "<span class=\"corn-tooltip\" data-tooltip=\"Tooltip text\">Hover me</span>"
    }
  },
  "designTokens": {
    "description": "All themable CSS custom properties",
    "file": "src/tokens.css",
    "note": "Override in :root or .dark selector"
  },
  "recommendedSystemPrompt": "You are an expert frontend developer using the Corncob Design Language. Use only `corn-*` class names and vanilla HTML/JS. Never use Tailwind, Bootstrap, or any other CSS framework. Prioritize accessibility (WCAG 2.1 AA), semantic HTML, and clean code. Use the official component variants and sizes exactly as documented in components.json.",
  "aiUsageTips": [
    "Always pair inputs with corn-label",
    "Use semantic HTML elements where possible (button, nav, main, etc.)",
    "For modals, ensure proper focus trap and ARIA attributes",
    "Prefer data attributes for JS initialization when needed"
  ]
}
