---
import ChevronRight from '@carbon/icons/svg/chevron--right.svg';

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL;

// A utility function can help handle edge cases like trailing slashes or nested routes
const isActive = (href: string) => {
  // Normalize paths by removing trailing slashes, but treat the home page '/' specially
  const normalizedPathname = pathname.replace(/\/$/, '') || '/';
  const normalizedHref = href.replace(/\/$/, '') || '/';

  // Mark only the exact page link as active to avoid multiple sidebar items being current.
  return normalizedPathname === normalizedHref;
};

const isTokensSection = pathname.includes('/tokens') ? true : null;
const isComponentsSection = pathname.includes('/components') ? true : null;
const isTestingSection = pathname.includes('/testing') ? true : null;
---

<div class="corn-panel-menu">
  <a
    href={`${base}getting-started/`}
    class="corn-panel-menu--item"
    aria-current={isActive(`${base}getting-started/`) ? 'page' : false}>Getting Started</a
  >
  <corn-expandable class="corn-expandable" open={isTokensSection} data-test={pathname}>
    <details slot="details">
      <summary class="corn-panel-menu--item corn-expandable-button">
        Tokens
        <ChevronRight class="corn-icon" aria-hidden="true" />
      </summary>
      <div class="corn-expandable--content">
        <div class="corn-panel-menu--submenu">
          <a
            href={`${base}tokens/animations`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/animations`) ? 'page' : false}>Animation</a
          >
          <a
            href={`${base}tokens/colors`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/colors`) ? 'page' : false}>Colors</a
          >
          <a
            href={`${base}tokens/borders`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/borders`) ? 'page' : false}>Borders</a
          >
          <a
            href={`${base}tokens/forms`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/forms`) ? 'page' : false}>Forms</a
          >
          <a
            href={`${base}tokens/shadows`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/shadows`) ? 'page' : false}>Shadows</a
          >
          <a
            href={`${base}tokens/sizes`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/sizes`) ? 'page' : false}>Sizes</a
          >
          <!-- <a
            href={`${base}tokens/spacing`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/spacing`) ? 'page' : false}>Spacing</a
          > -->
          <a
            href={`${base}tokens/typography`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}tokens/typography`) ? 'page' : false}>Typography</a
          >
        </div>
      </div>
    </details>
  </corn-expandable>
  <corn-expandable class="corn-expandable" open={isComponentsSection} data-test={pathname}>
    <details slot="details">
      <summary class="corn-panel-menu--item corn-expandable-button">
        Components
        <ChevronRight class="corn-icon" aria-hidden="true" />
      </summary>
      <div class="corn-expandable--content">
        <div class="corn-panel-menu--submenu">
          <a
            href={`${base}components/buttons`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/buttons`) ? 'page' : false}>Buttons</a
          >
          <a
            href={`${base}components/checkboxes`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/checkboxes`) ? 'page' : false}>Checkboxes</a
          >
          <a
            href={`${base}components/expandables`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/expandables`) ? 'page' : false}>Expandables</a
          >
          <a
            href={`${base}components/footers`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/footers`) ? 'page' : false}>Footers</a
          >
          <a
            href={`${base}components/headers`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/headers`) ? 'page' : false}>Headers</a
          >
          <a
            href={`${base}components/links`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/links`) ? 'page' : false}>Links</a
          >
          <a
            href={`${base}components/panel-menus`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/panel-menus`) ? 'page' : false}>Panel Menus</a
          >
          <a
            href={`${base}components/panels/`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/panels`) ? 'page' : false}>Panels</a
          >
          <a
            href={`${base}components/popovers`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/popovers`) ? 'page' : false}>Popovers</a
          >
          <a
            href={`${base}components/radio-buttons`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/radio-buttons`) ? 'page' : false}
            >Radio Buttons</a
          >
          <a
            href={`${base}components/text-inputs`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/text-inputs`) ? 'page' : false}>Text Inputs</a
          >
          <a
            href={`${base}components/tooltips`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}components/tooltips`) ? 'page' : false}>Tooltips</a
          >
        </div>
      </div>
    </details>
  </corn-expandable>
  <corn-expandable class="corn-expandable" open={isTestingSection} data-test={pathname}>
    <details slot="details">
      <summary class="corn-panel-menu--item corn-expandable-button">
        Testing
        <ChevronRight class="corn-icon" aria-hidden="true" />
      </summary>
      <div class="corn-expandable--content">
        <div class="corn-panel-menu--submenu">
          <a
            href={`${base}testing/`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}testing/`) ? 'page' : false}>Overview</a
          >
          <a
            href={`${base}testing/accessibility`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}testing/accessibility`) ? 'page' : false}
            >Accessibility</a
          >
          <a
            href={`${base}testing/visual`}
            class="corn-panel-menu--item"
            aria-current={isActive(`${base}testing/visual`) ? 'page' : false}>Visual</a
          >
        </div>
      </div>
    </details>
  </corn-expandable>
</div>
