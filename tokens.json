{
  "metadata": {
    "name": "Corncob Design Language Tokens",
    "version": "0.0.1",
    "description": "Structured design tokens for AI-assisted code generation and design system documentation",
    "aiIntegrationGuide": "See DESIGN_SYSTEM_FOR_AI.md for documentation on how AI systems should consume these files"
  },
  "colors": {
    "description": "Color palette using semantic naming with 10-step scales",
    "scales": {
      "yellow": {
        "10": "#faf6ed",
        "20": "#efe2bb",
        "30": "#dfcb87",
        "40": "#c9b03e",
        "50": "#a58d00",
        "60": "#837000",
        "70": "#665600",
        "80": "#4e4200",
        "90": "#393000",
        "100": "#282100"
      },
      "blue": {
        "10": "#d4fffa",
        "20": "#abefe8",
        "30": "#5be0d5",
        "40": "#00c5ba",
        "50": "#009f96",
        "60": "#007f77",
        "70": "#00625c",
        "80": "#004b46",
        "90": "#103633",
        "100": "#002724"
      },
      "orange": {
        "10": "#fef4f3",
        "20": "#fbdcd5",
        "30": "#f4c0b4",
        "40": "#e99e8b",
        "50": "#d47453",
        "60": "#b55429",
        "70": "#8e401e",
        "80": "#6d3015",
        "90": "#52220d",
        "100": "#3b1707"
      },
      "red": {
        "10": "#fcf5f5",
        "20": "#f5dddd",
        "30": "#eec2c1",
        "40": "#e69e9c",
        "50": "#df6a66",
        "60": "#c04944",
        "70": "#963733",
        "80": "#742926",
        "90": "#571d1a",
        "100": "#3f1311"
      },
      "green": {
        "10": "#ecfbe8",
        "20": "#b9f2a5",
        "30": "#a6da93",
        "40": "#90bd7f",
        "50": "#739866",
        "60": "#5b7950",
        "70": "#465d3d",
        "80": "#34472d",
        "90": "#263420",
        "100": "#192515"
      },
      "gray": {
        "10": "#f7f6f3",
        "20": "#e7e2d7",
        "30": "#d1ccbe",
        "40": "#b5b0a4",
        "50": "#928e84",
        "60": "#747169",
        "70": "#595751",
        "80": "#44423d",
        "90": "#32302c",
        "100": "#23211f"
      }
    },
    "semantic": {
      "white": "#fff",
      "black": "#000",
      "background": "{colors.scales.yellow.10}",
      "text": "{colors.scales.gray.100}",
      "textLight": "{colors.scales.gray.60}",
      "border": "{colors.scales.gray.70}",
      "success": "{colors.scales.green.60}",
      "error": "{colors.scales.red.60}",
      "warning": "{colors.scales.orange.60}",
      "info": "{colors.scales.blue.60}"
    }
  },
  "sizing": {
    "description": "Modular scale sizing system using major 3rd ratio (1.25)",
    "baseUnit": "1rem (16px)",
    "ratio": 1.25,
    "scale": {
      "-4": "6.554px",
      "-3": "8.192px",
      "-2": "10.24px",
      "-1": "12.8px",
      "0": "1rem (16px)",
      "1": "20px",
      "2": "25px",
      "3": "31.25px",
      "4": "39.063px",
      "5": "48.82px",
      "6": "61.035px",
      "7": "72.289px"
    }
  },
  "spacing": {
    "description": "Spacing values with 12px base unit",
    "unit": "0.75rem (12px)",
    "values": {
      "-2": "3px",
      "-1": "6px",
      "0": "12px",
      "1": "18px",
      "2": "24px",
      "3": "30px",
      "4": "36px",
      "5": "48px",
      "6": "60px",
      "7": "72px"
    }
  },
  "typography": {
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', roboto, 'Helvetica Neue', arial, 'Noto Sans', 'Liberation Sans', sans-serif",
    "fontFamilyMono": "'SFMono-Regular', consolas, 'Liberation Mono', menlo, courier, monospace",
    "sizes": {
      "xs": "var(--cc-size--2)",
      "sm": "var(--cc-size--1)",
      "base": "var(--cc-size-0)",
      "lg": "var(--cc-size-1)",
      "xl": "var(--cc-size-2)",
      "2xl": "var(--cc-size-3)",
      "3xl": "var(--cc-size-4)",
      "4xl": "var(--cc-size-5)"
    },
    "weights": {
      "thin": 100,
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeights": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    },
    "letterSpacing": {
      "tighter": "-0.05rem",
      "tight": "-0.025rem",
      "normal": "0rem",
      "wide": "0.025rem",
      "wider": "0.05rem"
    }
  },
  "borders": {
    "width": "1px",
    "style": "solid",
    "defaultColor": "{colors.scales.gray.70}",
    "radius": {
      "xs": "2px",
      "sm": "4px",
      "md": "4px",
      "lg": "8px",
      "xl": "12px",
      "2xl": "16px",
      "round": "50%",
      "full": "9999px"
    }
  },
  "transitions": {
    "easing": "ease-out",
    "durations": {
      "fast": "83ms",
      "base": "150ms",
      "slow": "333ms",
      "slower": "500ms"
    }
  },
  "components": {
    "button": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "variants": ["primary", "secondary", "danger"],
      "defaultVariant": "primary",
      "tokens": {
        "background": "{colors.scales.gray.100}",
        "color": "{colors.white}",
        "backgroundHover": "{colors.scales.gray.90}",
        "backgroundActive": "{colors.black}",
        "backgroundDisabled": "var(--cc-form--item--background--disabled)",
        "borderRadius": "4px",
        "borderWidth": "1px",
        "transitions": "background 150ms ease-out, color 150ms ease-out"
      }
    },
    "text-input": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "defaultSize": "md",
      "tokens": {
        "background": "var(--cc-form--item--color--background)",
        "backgroundHover": "var(--cc-form--item--color--background--hover)",
        "borderColor": "{colors.border}",
        "borderRadius": "4px",
        "labelColor": "{colors.scales.blue.60}",
        "labelFontWeight": 500
      }
    },
    "checkbox": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "defaultSize": "md",
      "states": ["unchecked", "checked", "indeterminate", "disabled"],
      "tokens": {
        "background": "var(--cc-form--item--color--background)",
        "backgroundChecked": "var(--cc-form--widget--background--selected)",
        "borderRadius": "4px",
        "checkColor": "var(--cc-form--widget--color)"
      }
    },
    "radio": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "defaultSize": "md",
      "tokens": {
        "background": "var(--cc-form--item--color--background)",
        "backgroundChecked": "var(--cc-form--widget--background--selected)",
        "borderRadius": "50%"
      }
    },
    "message": {
      "variants": ["info", "success", "error", "warning"],
      "tokens": {
        "info": {
          "background": "var(--cc-blue-20)",
          "color": "{colors.scales.blue.100}",
          "borderColor": "{colors.scales.blue.60}"
        },
        "success": {
          "background": "var(--cc-green-20)",
          "color": "{colors.scales.green.100}",
          "borderColor": "{colors.scales.green.60}"
        },
        "error": {
          "background": "var(--cc-red-20)",
          "color": "{colors.scales.red.100}",
          "borderColor": "{colors.scales.red.60}"
        },
        "warning": {
          "background": "var(--cc-orange-20)",
          "color": "{colors.scales.orange.100}",
          "borderColor": "{colors.scales.orange.60}"
        }
      }
    },
    "tooltip": {
      "positions": ["top", "right", "bottom", "left"],
      "defaultPosition": "top",
      "tokens": {
        "background": "{colors.scales.gray.100}",
        "color": "{colors.white}",
        "padding": "var(--cc-spacing-1) var(--cc-spacing-0)",
        "borderRadius": "4px",
        "maxWidth": "300px"
      }
    },
    "popover": {
      "positions": ["top", "right", "bottom", "left"],
      "defaultPosition": "bottom",
      "tokens": {
        "background": "{colors.white}",
        "border": "1px solid {colors.border}",
        "borderRadius": "4px",
        "boxShadow": "0 10px 25px rgba(0,0,0,0.1)",
        "padding": "var(--cc-spacing-0)"
      }
    },
    "expandable": {
      "tokens": {
        "transitionDuration": "150ms",
        "transitionEasing": "ease-out",
        "buttonBackground": "transparent",
        "buttonHoverBackground": "{colors.scales.gray.20}",
        "borderRadius": "4px"
      }
    },
    "panelMenu": {
      "tokens": {
        "itemPadding": "var(--cc-spacing-0)",
        "itemColor": "{colors.scales.gray.100}",
        "itemHoverBackground": "{colors.scales.gray.20}",
        "activeItemBackground": "{colors.scales.gray.90}",
        "activeItemColor": "{colors.white}",
        "borderRadius": "4px"
      }
    }
  },
  "accessibility": {
    "focusOutlineWidth": "2px",
    "focusOutlineColor": "{colors.scales.blue.60}",
    "focusOutlineOffset": "2px",
    "minTouchTargetSize": "44px",
    "minClickableSize": "24px"
  },
  "patterns": {
    "formControl": {
      "description": "Pattern for form inputs: label + input + status",
      "structure": [
        "div.corn-form--item",
        "  input or select or textarea",
        "  label",
        "  div.corn-status (optional)"
      ]
    },
    "formGroup": {
      "description": "Pattern for grouped form elements: fieldset + legend + items",
      "structure": [
        "fieldset.corn-form--item.corn-checkbox-group",
        "  legend",
        "  div.corn-checkbox (repeating)",
        "    input",
        "    label",
        "fieldset.corn-form--item.corn-radio-button-group",
        "  legend",
        "  div.corn-radio-button (repeating)",
        "    input",
        "    label"
      ]
    },
    "tooltipAnchor": {
      "description": "Pattern for tooltip: anchor wrapping button and tooltip",
      "structure": [
        "button.corn-button.corn-tooltip--anchor",
        "  text",
        "  corn-tooltip.corn-tooltip[position=top|right|bottom|left]"
      ]
    },
    "popoverTrigger": {
      "description": "Pattern for popover: anchor wrapping button and popover. Behavior: the trigger is associated with the popover by placement inside the same .corn-popover--anchor. Accessibility recommendation: the trigger may include aria-controls=popover-id to reference the popover, but this is not used by the JS to connect them.",
      "structure": [
        "div.corn-popover--anchor",
        "  button.corn-button.corn-pop",
        "  corn-popover.corn-popover#popover-id[position=top|right|bottom|left]"
      ]
    },
    "expandablePanel": {
      "description": "Pattern for expandable: web component wrapping native details",
      "structure": [
        "corn-expandable.corn-expandable",
        "  details[slot=details]",
        "    summary.corn-expandable-button",
        "    div.corn-expandable--content",
        "      content"
      ]
    }
  }
}
