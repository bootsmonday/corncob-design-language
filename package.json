{
  "name": "@corncob/edl",
  "version": "1.0.0",
  "description": "Corncob Design Language - A vanilla JavaScript design system",
  "main": "dist/edl.js",
  "module": "dist/edl.esm.js",
  "style": "dist/edl.css",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/corncob-edl.esm.js",
    "./style.css": "./dist/corncob-edl.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint:css": "stylelint src/**/*.css",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "keywords": [
    "design-system",
    "component-library",
    "vanilla-js",
    "enterprise"
  ],
  "author": "Corncob Team",
  "license": "MIT",
  "devDependencies": {
    "@carbon/icons": "^11.76.0",
    "@testing-library/dom": "^10.4.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.1.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "vite": "^7.3.1",
    "vite-plugin-string": "^1.2.3"
  }
}
